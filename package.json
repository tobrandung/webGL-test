  "description": "Web3D Studio — Create interactive 3D experiences with camera paths and export as embeddable widgets",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:widget": "vite build --config vite.config.widget.ts",
